# ── Banco de Dados ─────────────────────────────────────────────────
# MySQL local (Docker): mysql://tinder:senha@localhost:3306/tinder_iesgo
# MySQL VPS:            mysql://usuario:senha@ip-da-vps:3306/tinder_iesgo
DATABASE_URL="mysql://tinder:tinder123@localhost:3306/tinder_iesgo"

# ── Autenticação JWT ───────────────────────────────────────────────
# OBRIGATÓRIO em produção: string secreta longa e aleatória
# Gere com: openssl rand -base64 64
JWT_SECRET="troque-por-string-secreta-longa-e-aleatoria"

# ── Cookies ───────────────────────────────────────────────────────
# Ative para produção com HTTPS
SECURE_COOKIES="true"

# ── Email SMTP ─────────────────────────────────────────────────────
# Gmail: use senha de app (não a senha normal)
# Painel: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app-gmail"

# ── Modo demo ─────────────────────────────────────────────────────
# APENAS em desenvolvimento/eventos — exibe o código OTP na tela.
# REMOVA ou deixe vazio em produção real.
# DEMO_MODE="true"

# ── Google Gemini AI (opcional — geração de bio) ──────────────────
# GEMINI_API_KEY="sua-chave-gemini"
